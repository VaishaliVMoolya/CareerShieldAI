{
    "manifest_version": 3,
    "name": "CareerShield AI",
    "version": "1.0",
    "description": "AI Career Intelligence Assistant",

    "content_scripts": [
        {
            "matches": [
                "https://www.linkedin.com/jobs/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],

    "permissions": [
        "activeTab",
        "scripting"
    ],

    "host_permissions": [
        "https://www.linkedin.com/*"
    ],

    "action": {
        "default_popup": "popup.html"
    }
}